{
  "name": "navidrome-player-expo",
  "private": true,
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start -c",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "reset": "rm -rf node_modules .expo android ios index.js && npm install",
    "clean": "rm -rf .expo node_modules/.cache android ios index.js",
    "doctor": "npx expo-doctor",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate": "npm run typecheck && npm run lint && npm run format:check",
    "version:bump": "node scripts/bump-version.js",
    "post-prebuild-fix": "node scripts/post-prebuild-fix.js",
    "prebuild:android": "expo prebuild --platform android --clean && npm run post-prebuild-fix",
    "build:apk": "npm run prebuild:android && cd android && ./gradlew assembleRelease --no-daemon"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.21.0",
    "@react-native-community/netinfo": "11.1.0",
    "crypto-js": "^4.2.0",
    "expo": "~50.0.0",
    "expo-av": "~13.10.6",
    "expo-blur": "~12.9.2",
    "expo-build-properties": "~0.11.1",
    "expo-constants": "~15.4.6",
    "expo-crypto": "~12.8.1",
    "expo-linear-gradient": "~12.7.2",
    "expo-linking": "~6.2.2",
    "expo-router": "~3.4.10",
    "expo-secure-store": "~12.8.1",
    "expo-splash-screen": "~0.26.5",
    "expo-status-bar": "~1.11.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.73.6",
    "react-native-gesture-handler": "~2.14.0",
    "react-native-reanimated": "~3.6.2",
    "react-native-safe-area-context": "4.8.2",
    "react-native-screens": "~3.29.0",
    "react-native-track-player": "^4.1.1",
    "react-native-web": "~0.19.6",
    "zustand": "4.4.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/crypto-js": "^4.2.2",
    "@types/react": "~18.2.45",
    "@types/react-test-renderer": "^18.0.0",
    "eslint": "^8.57.0",
    "eslint-config-universe": "^12.0.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.0.0",
    "typescript": "^5.3.0"
  }
}
