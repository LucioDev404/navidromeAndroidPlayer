{
  "expo": {
    "name": "Navidrome Player",
    "slug": "navidrome-player-expo",
    "version": "1.0.0",
    "scheme": "navidrome-player",
    "orientation": "portrait",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "android": {
      "package": "com.navidrome.player"
    },
    "updates": {
      "enabled": false,
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "extra": {
      "apiBaseUrl": "https://your-navidrome-server.example.com"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 33,
            "targetSdkVersion": 33
          }
        }
      ]
    ]
  }
}
