{
  "expo": {
    "name": "Navidrome Player",
    "slug": "navidrome-player-expo",
    "version": "1.0.0",
    "scheme": "navidrome-player",
    "orientation": "portrait",
    "platforms": ["ios", "android", "web"],
    "android": {
      "package": "com.navidrome.player"
    },
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#050505"
    },
    "updates": {
      "enabled": false,
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": ["**/*"],
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "apiBaseUrl": "https://your-navidrome-server.example.com"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 34,
            "targetSdkVersion": 34,
            "buildToolsVersion": "34.0.0"
          }
        }
      ],
      "expo-secure-store"
    ]
  }
}
